# Vocal Visualizer - Environment Configuration
# Copy this to .env and fill in your values. NEVER commit .env to git.

# AWS Configuration (prefer using ~/.aws/credentials with named profiles instead)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
AWS_PROFILE=vocalvisualizer-dev

# Application
NODE_ENV=development
PORT=3000
